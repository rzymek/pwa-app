{
  "name": "tcs-calc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "deploy": "surge dist/ $NAME.surge.sh",
    "dev": "vite --host",
    "preview": "vite preview",
    "build": "npm-run-all clean -p check:* bundle",
    "clean": "rm -rf dist",
    "check:test": "vitest --run",
    "check:types": "tsc -b",
    "bundle": "run-s build:*",
    "build:bundle": "vite build",
    "build:icons": "pwa-assets-generator --root dist --preset minimal-2023 icon.svg",
    "build:z-clean": "rm -f vite.config.d.ts vite.config.js tsconfig*.tsbuildinfo"
  },
  "dependencies": {
    "@babel/plugin-transform-react-jsx-source": "^7.27.1",
    "@preact/preset-vite": "^2.10.5",
    "@testing-library/preact": "^3.2.4",
    "@vite-pwa/assets-generator": "^1.0.2",
    "jsdom": "^29.0.1",
    "npm-run-all": "^4.1.5",
    "preact": "^10.29.0",
    "remeda": "^2.33.7",
    "typescript": "^6.0.2",
    "vite": "8.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ],
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "devDependencies": {
    "surge": "^0.27.3"
  }
}
